# Ollama
OLLAMA_BASE_URL=http://localhost:11434
GENERAL_MODEL=llama3:8b
CODE_MODEL=qwen2.5-coder:7b

# Pipeline
DEFAULT_N_IDEAS=10
FAST_MODE=false
MVP_BUILD_COMMAND=npm run build
MVP_TEST_COMMAND=npm run test
MVP_INSTALL_COMMAND=npm install
MVP_DEV_COMMAND=npm run dev -- --hostname 127.0.0.1 --port 3000
MVP_DEV_BASE_URL=http://127.0.0.1:3000
MVP_DEV_STARTUP_TIMEOUT=35
MVP_DEV_CHECK_PATHS=/,/api/status,/api/health
REQUEST_TIMEOUT=20
RATE_LIMIT_PER_DOMAIN=2
MAX_SOURCES=8
RETRY_MAX_ATTEMPTS=3
RETRY_MIN_WAIT=1
RETRY_MAX_WAIT=6
MIN_PAGES=3
MIN_PAINS=3
MIN_COMPETITORS=1
MIN_AVG_TEXT_LEN=200
MIN_UNIQUE_DOMAINS=2
MARKET_SIGNAL_THRESHOLD=40
SIGNAL_SOURCES_TARGET=6
SIGNAL_PAINS_TARGET=8
SIGNAL_DOMAIN_TARGET=4
SIGNAL_REPEAT_TARGET=2

# Paths
RUNS_DIR=runs
DATA_DIR=data
CONFIG_DIR=configs
KNOWLEDGE_DIR=knowledge

# API
API_HOST=0.0.0.0
API_PORT=8000

# UI
UI_PORT=8501

# ============================================================================
# LLM CACHE CONFIGURATION - 80% PERFORMANCE IMPROVEMENT
# ============================================================================
# Enable intelligent LLM response caching
ENABLE_CACHE=true
CACHE_TTL=3600
CACHE_MAX_SIZE=10000
CACHE_SIMILARITY_THRESHOLD=0.85

# Redis configuration for cache
REDIS_URL=redis://localhost:6379/0
REDIS_CACHE_DB=1

# Cache performance tuning
CACHE_ASYNC_ENABLED=true
CACHE_BACKGROUND_CLEANUP=true
CACHE_COMPRESSION_ENABLED=true

# ============================================================================
# CONCURRENCY OPTIMIZATION - 5X THROUGHPUT
# ============================================================================
# Increased concurrent processing for maximum throughput
RUN_MAX_CONCURRENT=5
WORKER_CONCURRENCY=3
API_CONCURRENCY=10
UVICORN_WORKERS=2
UVICORN_BACKLOG=2048

# Queue and processing optimization
RQ_DEFAULT_TIMEOUT=3600
RQ_RESULT_TTL=86400
QUEUE_MAX_SIZE=1000
BATCH_PROCESSING_SIZE=10

# Resource limits for high concurrency
MAX_CONNECTIONS_PER_POOL=20
CONNECTION_TIMEOUT=30
READ_TIMEOUT=60
WRITE_TIMEOUT=60

# Performance tuning
ENABLE_ASYNC_TASKS=true
ASYNC_WORKERS=4
TASK_QUEUE_SIZE=500
BACKGROUND_PROCESSING=true
