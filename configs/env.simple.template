# =============================================================================
# CONFIGURATION SIMPLIFIÉE ASMblr - GÉRÉE PAR AGENTS
# =============================================================================
# Seules les variables essentielles et credentials sont ici
# Tout le reste est géré dynamiquement par les agents

# =============================================================================
# INFRASTRUCTURE ESSENTIELLE (NON MODIFIÉE PAR AGENTS)
# =============================================================================
OLLAMA_BASE_URL=http://localhost:11434
GENERAL_MODEL=llama3.1:8b
CODE_MODEL=qwen2.5-coder:7b

# =============================================================================
# SÉCURITÉ ET ACCÈS (NON MODIFIÉ PAR AGENTS)
# =============================================================================
API_KEY=
API_KEY_PREV=
API_KEY_PREV_EXPIRES_AT=
ENFORCE_KEY_ROTATION=true

# =============================================================================
# BASE DE DONNÉES ET STOCKAGE
# =============================================================================
REDIS_URL=redis://localhost:6379/0
RUNS_DIR=runs
DATA_DIR=data
CONFIG_DIR=configs
KNOWLEDGE_DIR=knowledge

# =============================================================================
# LOGGING ET MONITORING
# =============================================================================
LOG_JSON=false
AUDIT_LOG_FILE=data/audit.log

# =============================================================================
# SERVICES EXTERNES (CREDENTIALS SEULEMENT)
# =============================================================================
# Ollama models seront téléchargés automatiquement selon les besoins
# Les agents choisiront les modèles optimaux selon le contexte

# Services externes (optionnels - laisser vide si non utilisé)
VEO3_API_KEY=
GOOGLE_ADS_CLIENT_ID=
GOOGLE_ADS_CLIENT_SECRET=
META_ADS_ACCESS_TOKEN=
LINKEDIN_TOKEN=
X_BEARER_TOKEN=
YOUTUBE_TOKEN=
INSTAGRAM_TOKEN=

# =============================================================================
# DÉVELOPPEMENT ET TESTS
# =============================================================================
PROD_MODE=false
REQUIRE_PROD_CHECKLIST=false

# =============================================================================
# NOTES:
# =============================================================================
# - Les agents ajusteront automatiquement: n_ideas, max_sources, timeouts, seuils
# - La configuration s'adaptera selon: sujet, profil utilisateur, performances
# - Pour voir la configuration générée: configs/config_<topic>.json
# - Pour désactiver l'auto-configuration: set AGENT_AUTO_CONFIG=false
AGENT_AUTO_CONFIG=true
