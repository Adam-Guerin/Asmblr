diff --git a/mvp_repo/components/ui/empty-state.tsx b/mvp_repo/components/ui/empty-state.tsx
--- a/mvp_repo/components/ui/empty-state.tsx
+++ b/mvp_repo/components/ui/empty-state.tsx
@@ -0,0 +1,20 @@
+import { ReactNode } from 'react';

+

+export function EmptyState({

+  title,

+  description,

+  action,

+}: {

+  title: string;

+  description: string;

+  action?: ReactNode;

+}) {

+  return (

+    <div className="glass rounded-3xl p-6 text-center space-y-3">

+      <p className="text-xs uppercase tracking-[0.4em] text-slate-400">Empty state</p>

+      <h3 className="text-xl font-semibold text-white">{title}</h3>

+      <p className="text-slate-300">{description}</p>

+      {action ? <div className="flex justify-center">{action}</div> : null}

+    </div>

+  );

+}

