<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{{ product_name }} - MVP Landing</title>
    <link rel="stylesheet" href="./style.css" />
  </head>
  <body>
    <main class="page">
      <section class="hero">
        {% if logo_src %}
        <div class="brand-mark">
          <img class="brand-logo" src="{{ logo_src }}" alt="{{ logo_alt }}" />
        </div>
        {% endif %}
        <p class="eyebrow">{{ category }}</p>
        <h1>{{ hero_headline }}</h1>
        <p class="subhead">{{ hero_subhead }}</p>
        {% if value_prop_5s %}
        <p class="value-prop">{{ value_prop_5s }}</p>
        {% endif %}
        <button class="cta js-primary-cta" data-cta-intent="{{ cta_intent }}">{{ cta_primary }}</button>
      </section>
      <section class="section">
        <h2>Problem</h2>
        <p>{{ problem }}</p>
      </section>
      <section class="section">
        <h2>Solution</h2>
        <p>{{ solution_summary }}</p>
        <ul>
          {% for item in solution_does %}
          <li>{{ item }}</li>
          {% endfor %}
        </ul>
      </section>
      {% if social_proof_items %}
      <section class="section">
        <h2>{{ social_proof_title }}</h2>
        <ul>
          {% for proof in social_proof_items %}
          <li><strong>{{ proof.who }}</strong>: "{{ proof.quote }}" <em>({{ proof.source }})</em></li>
          {% endfor %}
        </ul>
      </section>
      {% endif %}
      {% if objections %}
      <section class="section">
        <h2>Objections</h2>
        <ul>
          {% for item in objections %}
          <li><strong>{{ item.objection }}</strong> {{ item.response }}</li>
          {% endfor %}
        </ul>
      </section>
      {% endif %}
      <section class="section">
        <h2>FAQ</h2>
        <ul>
          {% for item in faq %}
          <li><strong>{{ item.q }}</strong> {{ item.a }}</li>
          {% endfor %}
        </ul>
      </section>
      <section class="cta">
        <h2>{{ cta_heading }}</h2>
        <p>{{ cta_subhead }}</p>
        <button class="cta js-primary-cta" data-cta-intent="{{ cta_intent }}">{{ cta_primary }}</button>
      </section>
    </main>
    <script>
      (function () {
        var analytics = {{ analytics | tojson }};
        window.dataLayer = window.dataLayer || [];
        function track(eventName, payload) {
          if (!eventName) return;
          window.dataLayer.push(Object.assign({ event: eventName }, payload || {}));
        }
        track("page_view", {
          page_type: "landing",
          cta_intent: "{{ cta_intent }}",
          provider: analytics.provider || "default_js"
        });
        var ctaEvent = analytics.cta_event_name || "cta_click";
        var buttons = document.querySelectorAll(".js-primary-cta");
        buttons.forEach(function (button) {
          button.addEventListener("click", function () {
            track(ctaEvent, {
              cta_label: button.textContent.trim(),
              cta_intent: button.getAttribute("data-cta-intent") || "{{ cta_intent }}"
            });
          });
        });
      })();
    </script>
  </body>
</html>
