# Ollama
OLLAMA_BASE_URL=http://ollama:11434
GENERAL_MODEL=llama3.1:8b
CODE_MODEL=qwen2.5-coder:7b
GENERAL_MODEL_FALLBACKS=
CODE_MODEL_FALLBACKS=

# Pipeline
DEFAULT_N_IDEAS=10
FAST_MODE=false
MVP_BUILD_COMMAND=npm run build
MVP_TEST_COMMAND=npm run test
MVP_INSTALL_COMMAND=npm install
MVP_DEV_COMMAND=npm run dev -- --hostname 127.0.0.1 --port 3000
MVP_DEV_BASE_URL=http://127.0.0.1:3000
MVP_DEV_STARTUP_TIMEOUT=35
MVP_DEV_CHECK_PATHS=/,/api/status,/api/health
MVP_FORCE_AUTOFIX=false
MVP_DISABLE_LLM=false
REQUEST_TIMEOUT=20
RATE_LIMIT_PER_DOMAIN=2
MAX_SOURCES=8
RETRY_MAX_ATTEMPTS=3
RETRY_MIN_WAIT=1
RETRY_MAX_WAIT=6
ENABLE_SELF_HEALING=true
STAGE_RETRY_ATTEMPTS=2
STAGE_RETRY_BACKOFF_SEC=1.0
MIN_PAGES=3
MIN_PAINS=3
MIN_COMPETITORS=1
MIN_AVG_TEXT_LEN=200
MIN_UNIQUE_DOMAINS=2
MARKET_SIGNAL_THRESHOLD=40
SIGNAL_SOURCES_TARGET=6
SIGNAL_PAINS_TARGET=8
SIGNAL_DOMAIN_TARGET=4
SIGNAL_REPEAT_TARGET=2
SIGNAL_RECENCY_DAYS=365
ENABLE_PROGRESSIVE_CYCLES=true
ENABLE_LOGO_DIFFUSION=false
LOGO_MODEL_ID=runwayml/stable-diffusion-v1-5
LOGO_IMAGE_SIZE=512
LOGO_STEPS=28
LOGO_GUIDANCE=7.0
LOGO_SEED=0
LOGO_DEVICE=cuda
ENABLE_APP_PACKAGING=true
APP_PACKAGE_TARGETS=mvp_repo,landing_page,content_pack,distribution,hosting,brand_direction.md,brand_identity.json,logo.svg,launch_checklist.md,prd.md,tech_spec.md
ENABLE_DISTRIBUTION=true
PUBLIC_BASE_URL=
PUBLIC_BASE_DOMAIN=asmblr.com
PUBLIC_URL_TEMPLATE=https://{slug}.{domain}
OFFLINE_CREATION=false
ENABLE_LOCAL_SOCIAL_IMAGES=true
SOCIAL_IMAGE_MODEL_ID=runwayml/stable-diffusion-v1-5
SOCIAL_IMAGE_SIZE=768
SOCIAL_IMAGE_STEPS=28
SOCIAL_IMAGE_GUIDANCE=7.0
SOCIAL_IMAGE_SEED=0
ENABLE_LOCAL_VIDEO=true
LOCAL_VIDEO_MODEL_ID=stabilityai/stable-video-diffusion-img2vid-xt
LOCAL_VIDEO_FRAMES=24
LOCAL_VIDEO_FPS=8
ENABLE_VIDEO_GENERATION=true
VEO3_API_BASE=
VEO3_API_KEY=
VEO3_TIMEOUT_S=120
VEO3_POLL_INTERVAL_S=5
VEO3_SUBMIT_PATH=/generate
VEO3_STATUS_PATH=/status/{job_id}
VEO3_DOWNLOAD_PATH=/download/{job_id}
ENABLE_PUBLISHING=false
PUBLISH_DRY_RUN=true
PUBLISH_TIMEOUT_S=30
LINKEDIN_TOKEN=
LINKEDIN_AUTHOR=
X_BEARER_TOKEN=
X_USER_ID=
YOUTUBE_TOKEN=
YOUTUBE_CHANNEL_ID=
INSTAGRAM_TOKEN=
INSTAGRAM_ACCOUNT_ID=
ENABLE_ADS=false
ADS_DRY_RUN=true
ADS_TIMEOUT_S=30
ADS_BUDGET_USD=100
ADS_COUNTRIES=US
ADS_LANGUAGE=en
ADS_AUDIENCE=
ADS_INTERESTS=
GOOGLE_ADS_CUSTOMER_ID=
GOOGLE_ADS_DEV_TOKEN=
GOOGLE_ADS_CLIENT_ID=
GOOGLE_ADS_CLIENT_SECRET=
GOOGLE_ADS_REFRESH_TOKEN=
META_ADS_ACCESS_TOKEN=
META_ADS_ACCOUNT_ID=
TIKTOK_ADS_ACCESS_TOKEN=
TIKTOK_ADS_ACCOUNT_ID=
ENABLE_HOSTING=true
HOSTING_PROVIDER=aws_apprunner
HOSTING_DOMAIN=asmblr.com
HOSTING_SUBDOMAIN_TEMPLATE={slug}.{domain}

# Paths
RUNS_DIR=runs
DATA_DIR=data
CONFIG_DIR=configs
KNOWLEDGE_DIR=knowledge

# API
API_HOST=127.0.0.1
API_PORT=8000
API_KEY=
API_KEY_PREV=
LOG_JSON=false
RUN_RATE_LIMIT_PER_MIN=6
RUN_RATE_LIMIT_BURST=3
RUN_RETENTION_DAYS=30
RUN_MAX_COUNT=200
RUN_COMPRESS_AFTER_DAYS=7
RUN_MAINTENANCE_INTERVAL_MIN=60
RUN_ARCHIVE_DIRS=repo_skeleton,landing_page,content_pack,mvp_repo,mvp_cycles,project_build
BACKUP_DIR=data/backups
BACKUP_RETENTION_DAYS=14
AUDIT_LOG_FILE=data/audit.log
REDIS_URL=redis://localhost:6379/0
RQ_QUEUE_NAME=asmblr
RQ_DEFAULT_TIMEOUT=7200
RUN_MAX_CONCURRENT=1
RUN_QUEUE_BACKOFF_SEC=30
WORKER_PORT=8001

# UI
UI_HOST=127.0.0.1
UI_PORT=8501
UI_PASSWORD=
UI_PASSWORD_PREV=
