# Ollama
OLLAMA_BASE_URL=http://ollama:11434
GENERAL_MODEL=llama3.1:8b
CODE_MODEL=qwen2.5-coder:7b
GENERAL_MODEL_FALLBACKS=
CODE_MODEL_FALLBACKS=

# Pipeline
DEFAULT_N_IDEAS=10
FAST_MODE=false
MVP_BUILD_COMMAND=npm run build
MVP_TEST_COMMAND=npm run test
MVP_INSTALL_COMMAND=npm install
MVP_DEV_COMMAND=npm run dev -- --hostname 127.0.0.1 --port 3000
MVP_DEV_BASE_URL=http://127.0.0.1:3000
MVP_DEV_STARTUP_TIMEOUT=60
MVP_DEV_CHECK_PATHS=/,/api/status,/api/health,/docs
MVP_FORCE_AUTOFIX=true
MVP_DISABLE_LLM=false
REQUEST_TIMEOUT=45
RATE_LIMIT_PER_DOMAIN=3
MAX_SOURCES=12
RETRY_MAX_ATTEMPTS=5
RETRY_MIN_WAIT=2
RETRY_MAX_WAIT=10
ENABLE_SELF_HEALING=true
STAGE_RETRY_ATTEMPTS=2
STAGE_RETRY_BACKOFF_SEC=1.0
MIN_PAGES=3
MIN_PAINS=3
MIN_COMPETITORS=1
# ============================================================================
# SIGNAL PROCESSING THRESHOLDS
# ============================================================================
# These control market signal validation and quality requirements

# Minimum number of diverse sources needed for reliable market signal analysis
# Range: 3-10 recommended | Impact: Lower values may result in insufficient market diversity
SIGNAL_SOURCES_TARGET=6

# Target number of validated pain points for comprehensive market understanding  
# Range: 5-15 recommended | Impact: Fewer pains may miss key market needs
SIGNAL_PAINS_TARGET=8

# Minimum unique domains for cross-validation of market signals
# Range: 2-8 recommended | Impact: Ensures signals aren't from single source
SIGNAL_DOMAIN_TARGET=4

# Minimum repetitions of pain points to indicate market significance
# Range: 1-5 recommended | Impact: Higher values indicate stronger validation
SIGNAL_REPEAT_TARGET=2

# Time window for considering market signals as relevant (in days)
# Range: 90-730 recommended | Impact: Shorter = recent trends, longer = historical context
SIGNAL_RECENCY_DAYS=365

# Minimum average text length for meaningful signal extraction
# Range: 100-500 recommended | Impact: Shorter texts may lack context
MIN_AVG_TEXT_LEN=200

# Minimum unique domains to ensure source diversity
# Range: 2-5 recommended | Impact: Prevents over-reliance on single source
MIN_UNIQUE_DOMAINS=2

# Minimum market signal score for idea validation
# Range: 30-60 recommended | Impact: Higher thresholds require stronger evidence
MARKET_SIGNAL_THRESHOLD=45

# Minimum signal quality score for proceeding to idea generation
# Range: 40-70 recommended | Impact: Ensures sufficient market evidence before idea generation
SIGNAL_QUALITY_THRESHOLD=50

# ============================================================================
# FACILITATOR AGENTS FOR ENHANCED SYNERGY
# ============================================================================
# Enable enhanced collaboration between agents with facilitator coordination

# Enable facilitator agents for improved cross-agent collaboration and synergy
ENABLE_FACILITATOR_AGENTS=false

# Enable feedback loops for continuous agent improvement
ENABLE_FEEDBACK_LOOPS=false

# Enable shared knowledge base for collective intelligence
ENABLE_SHARED_KNOWLEDGE=false

# Enable peer review system for collaborative quality assurance
ENABLE_PEER_REVIEW=false

# Enable shared asset management for collaborative resource creation and reuse
ENABLE_SHARED_ASSETS=false

# Facilitator agent configuration
FACILITATOR_INSIGHT_SHARING_TARGET=80  # Target % of agents sharing insights
FACILITATOR_CONFLICT_RESOLUTION_TIMEOUT=300  # Max seconds to resolve conflicts
FACILITATOR_CROSS_VALIDATION_TARGET=70  # Target % of outputs validated
FACILITATOR_KNOWLEDGE_REUSE_TARGET=60  # Target % of learnings applied

# Feedback loop configuration
FEEDBACK_LOOP_QUALITY_THRESHOLD=70  # Minimum quality score to trigger feedback
FEEDBACK_LOOP_IMPROVEMENT_TARGET=0.15  # Target improvement per loop
FEEDBACK_LOOP_MAX_PENDING_ITEMS=10  # Max pending items before loop closure
FEEDBACK_LOOP_RESOLUTION_TIMEOUT=86400  # Max seconds to resolve feedback

# Shared knowledge base configuration
SHARED_KNOWLEDGE_VALIDATION_THRESHOLD=0.8  # Minimum validation score for knowledge
SHARED_KNOWLEDGE_SUCCESS_THRESHOLD=0.7  # Minimum success rate for knowledge
SHARED_KNOWLEDGE_MIN_USAGE=5  # Minimum usage before considering validation
SHARED_KNOWLEDGE_MAX_ENTRIES=10000  # Maximum entries in knowledge base
SHARED_KNOWLEDGE_RETENTION_DAYS=365  # Days to retain unused knowledge

# Peer review configuration
PEER_REVIEW_MIN_REVIEWERS=2  # Minimum reviewers per artifact
PEER_REVIEW_MAX_REVIEWERS=4  # Maximum reviewers per artifact
PEER_REVIEW_ASSIGNMENT_TIMEOUT=3600  # Max seconds to accept review assignment
PEER_REVIEW_COMPLETION_TIMEOUT=86400  # Max seconds to complete review
PEER_REVIEW_QUALITY_THRESHOLD=3.0  # Minimum average score for approval
PEER_REVIEW_AUTO_ASSIGNMENT=true  # Automatically assign reviewers based on expertise

# Shared asset management configuration
SHARED_ASSETS_MAX_FILE_SIZE=50000000  # Maximum file size in bytes (50MB)
SHARED_ASSETS_APPROVAL_REQUIRED=true  # Require approval before publishing assets
SHARED_ASSETS_AUTO_CATEGORIZATION=true  # Automatically categorize assets based on content
SHARED_ASSETS_USAGE_TRACKING=true  # Track asset usage and popularity
SHARED_ASSETS_VERSION_CONTROL=true  # Maintain version history for assets
SHARED_ASSETS_QUALITY_STANDARDS=true  # Enforce minimum quality standards for assets

# ============================================================================
# MVP QUALITY ENHANCEMENT
# ============================================================================
# Enhanced settings for better MVP generation quality

# Enable comprehensive quality checks during MVP building
MVP_ENABLE_QUALITY_CHECKS=true

# Minimum quality score threshold for MVP acceptance (0-100)
MVP_QUALITY_THRESHOLD=65

# Enable automatic fixes for common MVP issues
MVP_ENABLE_AUTO_FIXES=true

# Maximum number of improvement iterations
MVP_MAX_IMPROVEMENT_ITERATIONS=3

# MVP stack preferences for better quality
MVP_PREFERRED_FRONTEND=nextjs
MVP_PREFERRED_BACKEND=fastapi
MVP_PREFERRED_DATABASE=sqlite
MVP_PREFERRED_STYLING=tailwind

# Enable progressive enhancement cycles
MVP_ENABLE_PROGRESSIVE_ENHANCEMENT=true
MVP_ENHANCEMENT_CYCLES=foundation,ux,polish,optimization

# ============================================================================
# MLP (MOST LOVABLE PRODUCT) CONFIGURATION
# ============================================================================
# Advanced settings for creating products users can't live without

# Enable MLP features (Most Lovable Product instead of MVP)
MLP_ENABLED=true

# MLP quality thresholds (higher than MVP for emotional addiction)
MLP_LOVEABILITY_THRESHOLD=80
MLP_EMOTIONAL_THRESHOLD=75
MLP_HABIT_THRESHOLD=70
MLP_COMMUNITY_THRESHOLD=65

# Enable loveability engineering and emotional addiction systems
LOVEABILITY_ENABLED=true

# ============================================================================
# EMOTIONAL DESIGN ENHANCEMENT
# ============================================================================
# Advanced settings for creating emotionally resonant MVPs

# Enable emotional design patterns and psychology-driven UX
EMOTIONAL_DESIGN_ENABLED=true

# Primary emotional theme for the product (joy, trust, delight, pride, connection, comfort)
PRIMARY_EMOTIONAL_THEME=joy

# Enable celebration system for achievements and milestones
ENABLE_CELEBRATION_SYSTEM=true

# Enable personalized emotional experiences
ENABLE_EMOTIONAL_PERSONALIZATION=true

# Emotional animation intensity (subtle, moderate, expressive)
EMOTIONAL_ANIMATION_INTENSITY=moderate

# Enable haptic feedback on mobile devices
ENABLE_HAPTIC_FEEDBACK=true

# Enable sound design for emotional moments
ENABLE_EMOTIONAL_SOUNDS=true

# Community and belonging features
ENABLE_COMMUNITY_FEATURES=true

# Emotional analytics and user mood tracking
ENABLE_EMOTIONAL_ANALYTICS=true

# Celebration trigger sensitivity (low, medium, high)
CELEBRATION_SENSITIVITY=medium

# Personalization learning rate (how fast to adapt to user preferences)
EMOTIONAL_LEARNING_RATE=0.15

# Micro-interaction delight frequency (percentage of interactions)
DELIGHT_INTERACTION_FREQUENCY=0.3
# ============================================================================
# These control how ideas are evaluated and selected for development

# Threshold for considering an idea "actionable" (minimum viable for MVP)
# Range: 40-70 recommended | Impact: Lower = more experimental, higher = stronger validation
# Calculation: Based on 50% being neutral, +5 for minimum viability buffer
IDEA_ACTIONABILITY_MIN_SCORE=50

# Maximum score adjustment for actionability to prevent over-inflation
# Range: 5-25 recommended | Impact: Caps influence of actionability on final scores
# Formula: max_score_adjustment = 25% of total score range
IDEA_ACTIONABILITY_ADJUSTMENT_MAX=12

# Require at least one actionable idea to proceed (true=abort, false=use best available)
# Impact: true = stricter quality control, false = more flexible execution
IDEA_ACTIONABILITY_REQUIRE_ELIGIBLE_TOP=false

# ============================================================================
# HISTORICAL LEARNING
# ============================================================================
# These control how the system learns from previous runs

# Maximum historical runs to consider for learning (prevents memory bloat)
# Range: 50-500 recommended | Impact: Larger = more data but slower processing
LEARNING_HISTORY_MAX_RUNS=200

# Default exploration rate (0.0-1.0) for balancing known patterns vs. new ideas
# Higher = more exploration, Lower = more exploitation of known successful patterns
LEARNING_EXPLORATION_RATE=0.18

# Maximum bonus for success patterns in historical learning
# Range: 5-15 recommended | Impact: Higher values reward proven patterns more
LEARNING_SUCCESS_BONUS_MAX=8

# Maximum penalty for failure patterns in historical learning
# Range: 5-20 recommended | Impact: Higher values penalize failed patterns more
LEARNING_FAILURE_PENALTY_MAX=10

# Maximum bonus for novel ideas in historical learning
# Range: 3-10 recommended | Impact: Higher values encourage innovation
LEARNING_NOVELTY_BONUS_MAX=6

# Starting point for clone penalty (0.0-1.0) in historical learning
# Higher values penalize similar ideas more strongly
LEARNING_CLONE_PENALTY_START=0.75
PRIMARY_ICP=Founders B2B SaaS pre-seed
PRIMARY_ICP_KEYWORDS=founder,founders,b2b,saas,pre-seed,startup,startups,small team,operators
ICP_ALIGNMENT_BONUS_MAX=8
