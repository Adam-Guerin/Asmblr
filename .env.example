# Asmblr Environment Configuration
# Copy this file to .env and customize for your environment

# AI Model Configuration
OLLAMA_BASE_URL=http://localhost:11434
GENERAL_MODEL=llama3.1:8b
CODE_MODEL=qwen2.5-coder:7b

# Server Configuration
API_HOST=localhost
API_PORT=8000
UI_HOST=localhost
UI_PORT=8501

# Performance Configuration
MAX_SOURCES=10
REQUEST_TIMEOUT=300
MAX_CONCURRENT_REQUESTS=5

# Logging Configuration
LOG_LEVEL=INFO
ENABLE_PERFORMANCE_LOGGING=true
ENABLE_ERROR_DETAILS=true

# MVP Configuration
MVP_INSTALL_TIMEOUT=600
MVP_BUILD_TIMEOUT=300
MVP_TEST_TIMEOUT=300
MVP_DEV_COMMAND=npm run dev -- --hostname 127.0.0.1 --port 3000
MVP_DEV_BASE_URL=http://127.0.0.1:3000
MVP_DEV_STARTUP_TIMEOUT=60
MVP_DEV_CHECK_PATHS=/,/api/status,/api/health,/docs
MVP_FORCE_AUTOFIX=true
MVP_DISABLE_LLM=false

# Feature Flags
ENABLE_PROGRESSIVE_CYCLES=true
ENABLE_LOGO_DIFFUSION=false
ENABLE_DEMO_MODE=false

# Signal Processing Configuration
SIGNAL_SOURCES_TARGET=6
SIGNAL_PAINS_TARGET=8
SIGNAL_DOMAIN_TARGET=4
SIGNAL_REPEAT_TARGET=2
SIGNAL_RECENCY_DAYS=365
MIN_AVG_TEXT_LEN=200
MIN_UNIQUE_DOMAINS=2
MARKET_SIGNAL_THRESHOLD=45
SIGNAL_QUALITY_THRESHOLD=50

# Idea Generation Configuration
IDEA_ACTIONABILITY_MIN_SCORE=50
IDEA_ACTIONABILITY_ADJUSTMENT_MAX=12
IDEA_ACTIONABILITY_REQUIRE_ELIGIBLE_TOP=false

# Learning Configuration
LEARNING_HISTORY_MAX_RUNS=200
LEARNING_EXPLORATION_RATE=0.18
LEARNING_SUCCESS_BONUS_MAX=8
LEARNING_FAILURE_PENALTY_MAX=10
LEARNING_NOVELTY_BONUS_MAX=6
LEARNING_CLONE_PENALTY_START=0.75

# Retry Configuration
DEFAULT_N_IDEAS=10
FAST_MODE=false
RATE_LIMIT_PER_DOMAIN=3
RETRY_MAX_ATTEMPTS=5
RETRY_MIN_WAIT=2
RETRY_MAX_WAIT=10
MIN_PAGES=3
MIN_PAINS=3
MIN_COMPETITORS=1

# Paths
RUNS_DIR=runs
DATA_DIR=data
CONFIG_DIR=configs
KNOWLEDGE_DIR=knowledge

# Security
PROD_MODE=false
REQUIRE_PROD_CHECKLIST=true
ENFORCE_KEY_ROTATION=true

# Rate Limiting
RUN_RATE_LIMIT_PER_MIN=3
REQUEST_RATE_LIMIT_PER_MIN=60

# Development
DEBUG=false
LIGHTWEIGHT_MODE=false
